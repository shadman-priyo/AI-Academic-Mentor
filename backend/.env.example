# =============================================
# AI ACADEMIC MENTOR — ENVIRONMENT VARIABLES
# CSE4104-7C-T05 | NUBTK 2026 | Week 07 (fixed)
# =============================================
# DO NOT COMMIT THE REAL .env FILE TO GITHUB
# Add .env to your .gitignore file
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================

PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai_academic_mentor?retryWrites=true&w=majority

JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=7d

# Gemini API Key — MUST start with "AIza". Get it from:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_real_AIza_gemini_key_here

# Free HuggingFace inference token (fallback provider) — free tier, still rate-limited.
# https://huggingface.co/settings/tokens
HF_ACCESS_TOKEN=your_huggingface_token_here

# Server-side admin signup gate — change this before deploying for real.
ADMIN_ACCESS_CODE=CHANGE_ME

# Frontend URL for CORS (your Netlify/Vercel domain in production)
CLIENT_URL=http://localhost:3000
